# Copy to .env and fill in. All are optional — the site builds without them
# and falls back to local data / placeholder embeds.

# Canonical production origin (used for SEO canonical URLs + sitemap).
SITE_URL=https://unexplo.com

# --- Kanban / Roadmap (synced from GitHub Projects v2) ---
# A GitHub token with `read:project` scope (classic) or a fine-grained token
# with Projects read access. Without it, the roadmap falls back to
# src/data/roadmap.ts. Build-time only; never shipped to the client.
GITHUB_TOKEN=
# The org login that owns the project board.
GITHUB_ORG=Unexplo
# The Projects v2 number (the integer in the project URL, e.g. /orgs/Unexplo/projects/3 -> 3).
GITHUB_PROJECT_NUMBER=

# --- Newsletter embed (Unexplored) ---
# Form action URL from your provider (Buttondown / ConvertKit / Substack / etc.).
PUBLIC_NEWSLETTER_ACTION=

# --- Academy: Intro to AI registration (30 seats) ---
# Embeddable form URL (Tally / Google Forms / Luma). Rendered in an iframe.
PUBLIC_ACADEMY_FORM_URL=
