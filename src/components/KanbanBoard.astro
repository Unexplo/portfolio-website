---
import { getRoadmap } from "@/lib/github-projects";

const { items, columns, source, projectTitle } = await getRoadmap();

const byColumn = columns.map((col) => ({
  name: col,
  items: items.filter((i) => i.status === col),
}));

const dotColor: Record<string, string> = {
  Backlog: "var(--color-muted)",
  "In progress": "var(--color-coral)",
  Shipped: "var(--color-emerald)",
};
---

<div>
  <div class="mb-4 flex items-center gap-2 text-xs text-[var(--color-ink-2)]">
    <span class="font-mono">
      {source === "github"
        ? `Live from GitHub Projects${projectTitle ? ` · ${projectTitle}` : ""}`
        : "Roadmap snapshot"}
    </span>
    <span class="h-1.5 w-1.5 rounded-full" style={`background:${source === "github" ? "var(--color-emerald)" : "var(--color-muted)"}`}></span>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    {byColumn.map((col) => (
      <section class="card flex flex-col gap-3 p-4" aria-label={col.name}>
        <header class="flex items-center justify-between">
          <h3 class="flex items-center gap-2 font-display text-lg">
            <span class="h-2 w-2 rounded-full" style={`background:${dotColor[col.name]}`}></span>
            {col.name}
          </h3>
          <span class="font-mono text-xs text-[var(--color-ink-2)]">{col.items.length}</span>
        </header>

        <ul class="flex flex-col gap-2.5">
          {col.items.length === 0 && (
            <li class="rounded-lg border border-dashed border-[var(--color-line)] px-3 py-6 text-center text-xs text-[var(--color-ink-2)]">
              Nothing here yet
            </li>
          )}
          {col.items.map((item) => (
            <li class="rounded-lg border border-[var(--color-line)] bg-[var(--color-paper)] p-3">
              <div class="flex items-start justify-between gap-2">
                <p class="text-sm font-medium leading-snug">{item.title}</p>
                {item.area && (
                  <span class="shrink-0 rounded-full bg-[var(--color-paper-2)] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-[var(--color-ink-2)]">
                    {item.area}
                  </span>
                )}
              </div>
              {item.note && <p class="mt-1.5 text-xs leading-relaxed text-[var(--color-ink-2)]">{item.note}</p>}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</div>
