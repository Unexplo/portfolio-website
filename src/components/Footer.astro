---
import { nav, socials, site } from "@/data/site";
import Icon from "@/components/Icon.astro";
const year = 2026;
---

<footer class="mt-20 border-t border-[var(--color-line)]">
  <div class="wrap flex flex-col gap-8 py-10 md:flex-row md:items-start md:justify-between">
    <div class="max-w-xs">
      <a href="/" class="font-display text-lg">{site.name}</a>
      <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-2)]">{site.tagline}</p>
      <a href={`mailto:${site.email}`} class="mt-3 inline-block text-sm text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
        {site.email}
      </a>
    </div>

    <div class="flex gap-12 sm:gap-16">
      <nav aria-label="Footer">
        <h2 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Explore</h2>
        <ul class="mt-3 flex flex-col gap-2 text-sm">
          {nav.map((item) => (
            <li><a href={item.href} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div>
        <h2 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Connect</h2>
        <ul class="mt-3 flex flex-col gap-2 text-sm">
          {socials.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener" class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{s.label}</a>
            </li>
          ))}
          <li><a href="/llms.txt" class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">llms.txt</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="wrap flex items-center justify-between border-t border-[var(--color-line)] py-5 text-xs text-[var(--color-ink-2)]">
    <p>© {year} {site.name}</p>
    <div class="flex items-center gap-4">
      {socials.map((s) => (
        <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
          <Icon name={s.icon as "github" | "x"} />
        </a>
      ))}
    </div>
  </div>
</footer>
