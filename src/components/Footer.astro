---
import { nav, socials, site, newsletter } from "@/data/site";
import NewsletterForm from "@/components/NewsletterForm.astro";
const year = 2026;
---

<footer class="mt-20 border-t border-[var(--color-line)]">
  <div class="wrap grid grid-cols-2 gap-x-8 gap-y-10 py-12 lg:grid-cols-[1.4fr_1fr_1fr_1.7fr]">
    <!-- Column 1: Brand -->
    <div class="col-span-2 lg:col-span-1">
      <a href="/" class="font-display text-lg">{site.name}</a>
      <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-2)]">{site.tagline}</p>
      <a href={`mailto:${site.email}`} class="mt-3 inline-block text-sm text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
        {site.email}
      </a>
      <p class="mt-6 text-xs text-[var(--color-muted)]">© {year} {site.name}. All rights reserved.</p>
    </div>

    <!-- Column 2: Explore (sitemap) -->
    <nav aria-label="Sitemap">
      <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Explore</h3>
      <ul class="mt-4 flex flex-col gap-2.5 text-sm">
        {nav.map((item) => (
          <li><a href={item.href} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Column 3: Connect -->
    <div>
      <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Connect</h3>
      <ul class="mt-4 flex flex-col gap-2.5 text-sm">
        {socials.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener" class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{s.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 4: Subscribe -->
    <div class="col-span-2 lg:col-span-1">
      <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Subscribe</h3>
      <p class="mt-4 text-sm text-[var(--color-ink-2)]">{newsletter.name} — {newsletter.tagline}</p>
      <div class="mt-3"><NewsletterForm compact /></div>
    </div>
  </div>
</footer>
