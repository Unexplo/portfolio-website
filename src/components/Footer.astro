---
import { socials, site, newsletter } from "@/data/site";
import Icon from "@/components/Icon.astro";
const year = 2026;

const labelClass = "font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]";
const linkClass = "text-[var(--color-ink-2)] hover:text-[var(--color-ink)]";
---

<footer class="mt-20 border-t border-[var(--color-line)]">
  <div class="wrap py-12">
    <!-- Brand -->
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-md">
        <a href="/" class="font-display text-lg">{site.name}</a>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-2)]">{site.tagline}</p>
      </div>
      <div class="flex items-center gap-4">
        {socials.map((s) => (
          <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} class={linkClass}>
            <Icon name={s.icon as "github" | "x"} />
          </a>
        ))}
      </div>
    </div>

    <!-- Columns -->
    <div class="mt-10 grid grid-cols-1 items-start gap-8 sm:grid-cols-2 lg:grid-cols-[2.4fr_1fr_1fr]">
      <!-- 1. Stay in touch (card panel, fills column height) -->
      <div class="card flex h-full flex-col justify-center gap-3 p-8">
        <h3 class={labelClass}>Stay in touch</h3>
        <p class="text-sm text-[var(--color-ink-2)]">{newsletter.name} — {newsletter.tagline}</p>
        <a href="/newsletter" class="btn btn-primary mt-1 self-start !py-1.5 !text-sm">
          Subscribe <Icon name="arrow" />
        </a>
      </div>

      <!-- 2. Explore + Labs -->
      <div>
        <nav aria-label="Explore">
          <h3 class={labelClass}>Explore</h3>
          <ul class="mt-4 flex flex-col gap-2.5 text-sm">
            <li><a href="/" class={linkClass}>Home</a></li>
            <li><a href="https://github.com/Unexplo" target="_blank" rel="noopener" class={linkClass}>Open source</a></li>
          </ul>
        </nav>
        <nav aria-label="Labs" class="mt-6">
          <h3 class={labelClass}>Labs</h3>
          <ul class="mt-4 flex flex-col gap-2.5 text-sm">
            <li><a href="/labs" class={linkClass}>All projects</a></li>
          </ul>
        </nav>
      </div>

      <!-- 3. Academy + Roadmap -->
      <div>
        <nav aria-label="Academy">
          <h3 class={labelClass}>Academy</h3>
          <ul class="mt-4 flex flex-col gap-2.5 text-sm">
            <li><a href="/academy" class={linkClass}>Intro to AI</a></li>
            <li><a href="/academy#register" class={linkClass}>Register</a></li>
          </ul>
        </nav>
        <nav aria-label="Roadmap" class="mt-6">
          <h3 class={labelClass}>Roadmap</h3>
          <ul class="mt-4 flex flex-col gap-2.5 text-sm">
            <li><a href="/roadmap" class={linkClass}>What we're building</a></li>
          </ul>
        </nav>
      </div>
    </div>
  </div>

  <!-- Bottom bar: contact + copyright -->
  <div class="wrap flex flex-col gap-2 border-t border-[var(--color-line)] py-5 text-xs text-[var(--color-ink-2)] sm:flex-row sm:items-center sm:justify-between">
    <a href={`mailto:${site.email}`} class="hover:text-[var(--color-ink)]">{site.email}</a>
    <p>© {year} {site.name}. All rights reserved.</p>
  </div>
</footer>
