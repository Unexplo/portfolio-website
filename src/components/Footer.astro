---
import { nav, socials, site } from "@/data/site";
import Icon from "@/components/Icon.astro";
const year = 2026;
---

<footer class="mt-24 border-t border-[var(--color-line)]">
  <div class="wrap grid gap-10 py-14 md:grid-cols-[1.5fr_1fr_1fr]">
    <div>
      <a href="/" class="font-display text-xl">
        {site.name}
      </a>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-[var(--color-ink-2)]">
        {site.tagline}
      </p>
      <a href={`mailto:${site.email}`} class="mt-4 inline-flex items-center gap-2 text-sm text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
        <Icon name="mail" /> {site.email}
      </a>
    </div>

    <nav aria-label="Footer">
      <h2 class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-ink-2)]">Explore</h2>
      <ul class="mt-4 flex flex-col gap-2.5 text-sm">
        {nav.map((item) => (
          <li><a href={item.href} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div>
      <h2 class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-ink-2)]">Elsewhere</h2>
      <ul class="mt-4 flex flex-col gap-2.5 text-sm">
        {socials.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
              <Icon name={s.icon as "github" | "x"} /> {s.label} <span class="text-[var(--color-muted)]">{s.handle}</span>
            </a>
          </li>
        ))}
        <li><a href="/llms.txt" class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">llms.txt</a></li>
      </ul>
    </div>
  </div>

  <div class="wrap flex flex-col items-center justify-between gap-2 border-t border-[var(--color-line)] py-6 text-xs text-[var(--color-ink-2)] sm:flex-row">
    <p>© {year} {site.name}. Built and operated end-to-end.</p>
    <p class="font-mono">Made with Claude.</p>
  </div>
</footer>
