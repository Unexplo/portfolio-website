---
import { nav, socials, site, newsletter } from "@/data/site";
import NewsletterForm from "@/components/NewsletterForm.astro";
import Icon from "@/components/Icon.astro";
const year = 2026;
---

<footer class="mt-20 border-t border-[var(--color-line)]">
  <div class="wrap py-12">
    <!-- Brand (with social icons) -->
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-md">
        <a href="/" class="font-display text-lg">{site.name}</a>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-2)]">{site.tagline}</p>
      </div>
      <div class="flex items-center gap-4">
        {socials.map((s) => (
          <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
            <Icon name={s.icon as "github" | "x"} />
          </a>
        ))}
      </div>
    </div>

    <!-- Explore row -->
    <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
      <h3 class="shrink-0 font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Explore</h3>
      <nav aria-label="Sitemap" class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        {nav.map((item) => (
          <a href={item.href} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{item.label}</a>
        ))}
      </nav>
    </div>

    <!-- Subscribe row -->
    <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
      <div>
        <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Subscribe</h3>
        <p class="mt-2 text-sm text-[var(--color-ink-2)]">{newsletter.name} — {newsletter.tagline}</p>
      </div>
      <div class="w-full sm:max-w-sm"><NewsletterForm compact /></div>
    </div>
  </div>

  <!-- Bottom bar: contact + copyright, below the columns -->
  <div class="wrap flex flex-col gap-2 border-t border-[var(--color-line)] py-5 text-xs text-[var(--color-ink-2)] sm:flex-row sm:items-center sm:justify-between">
    <a href={`mailto:${site.email}`} class="hover:text-[var(--color-ink)]">{site.email}</a>
    <p>© {year} {site.name}. All rights reserved.</p>
  </div>
</footer>
