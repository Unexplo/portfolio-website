---
import { nav, socials, site } from "@/data/site";
import Icon from "@/components/Icon.astro";
const year = 2026;
---

<footer class="mt-20 border-t border-[var(--color-line)]">
  <div class="wrap py-12">
    <!-- Brand row: wordmark · centered tagline · social icons -->
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <a href="/" class="font-display text-lg leading-none">{site.name}</a>

      <span class="text-sm text-[var(--color-ink-2)] sm:flex-1 sm:px-6 sm:text-center">{site.tagline}</span>

      <div class="flex items-center gap-4">
        {socials.map((s) => (
          <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
            <Icon name={s.icon as "github" | "x"} />
          </a>
        ))}
      </div>
    </div>

    <!-- Explore (one row) · Subscribe button -->
    <div class="mt-10 flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
        <h3 class="shrink-0 font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Explore</h3>
        <nav aria-label="Sitemap" class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
          {nav.map((item) => (
            <a href={item.href} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{item.label}</a>
          ))}
        </nav>
      </div>

      <a href="/newsletter" class="btn btn-primary shrink-0">
        Subscribe to newsletter <Icon name="arrow" />
      </a>
    </div>
  </div>

  <!-- Bottom bar: contact + copyright -->
  <div class="wrap flex flex-col gap-2 border-t border-[var(--color-line)] py-5 text-xs text-[var(--color-ink-2)] sm:flex-row sm:items-center sm:justify-between">
    <a href={`mailto:${site.email}`} class="hover:text-[var(--color-ink)]">{site.email}</a>
    <p>© {year} {site.name}. All rights reserved.</p>
  </div>
</footer>
