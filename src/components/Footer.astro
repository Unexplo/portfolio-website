---
import { nav, socials, site } from "@/data/site";
import Icon from "@/components/Icon.astro";
const year = 2026;
---

<footer class="mt-20 border-t border-[var(--color-line)]">
  <div class="wrap py-8">
    <!-- Row 1: wordmark · centered tagline · socials -->
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <a href="/" class="font-display text-lg leading-none">{site.name}</a>

      <span class="text-sm text-[var(--color-ink-2)] sm:flex-1 sm:px-6 sm:text-center">{site.tagline}</span>

      <div class="flex items-center gap-4">
        {socials.map((s) => (
          <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
            <Icon name={s.icon as "github" | "x"} />
          </a>
        ))}
      </div>
    </div>

    <!-- Row 2: nav (centered) -->
    <nav aria-label="Footer" class="mt-6 flex flex-wrap justify-center gap-x-5 gap-y-2 text-sm">
      {nav.map((item) => (
        <a href={item.href} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{item.label}</a>
      ))}
    </nav>

    <!-- Row 3: copyright · contact -->
    <div class="mt-6 flex flex-col gap-1 border-t border-[var(--color-line)] pt-5 text-xs text-[var(--color-ink-2)] sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {site.name}. All rights reserved.</p>
      <a href={`mailto:${site.email}`} class="hover:text-[var(--color-ink)]">{site.email}</a>
    </div>
  </div>
</footer>
