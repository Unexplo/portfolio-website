---
import { nav, socials, site, newsletter } from "@/data/site";
import NewsletterForm from "@/components/NewsletterForm.astro";
import Icon from "@/components/Icon.astro";
const year = 2026;
---

<footer class="mt-20 border-t border-[var(--color-line)]">
  <!-- CTA band: catch visitors with the newsletter before they leave -->
  <div class="wrap flex flex-col gap-5 border-b border-[var(--color-line)] py-10 md:flex-row md:items-center md:justify-between">
    <div class="max-w-md">
      <h2 class="font-display text-xl">{newsletter.name} — stay in the loop</h2>
      <p class="mt-1 text-sm text-[var(--color-ink-2)]">{newsletter.tagline}</p>
    </div>
    <div class="w-full md:max-w-sm">
      <NewsletterForm compact />
    </div>
  </div>

  <!-- Main: brand + sitemap nav -->
  <div class="wrap flex flex-col gap-8 py-10 md:flex-row md:justify-between">
    <div class="max-w-xs">
      <a href="/" class="font-display text-lg">{site.name}</a>
      <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-2)]">{site.tagline}</p>
      <a href={`mailto:${site.email}`} class="mt-3 inline-block text-sm text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
        {site.email}
      </a>
    </div>

    <nav aria-label="Sitemap">
      <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Explore</h3>
      <ul class="mt-3 grid grid-cols-2 gap-x-12 gap-y-2 text-sm sm:grid-cols-3">
        {nav.map((item) => (
          <li><a href={item.href} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <!-- Legal / social bar -->
  <div class="wrap flex flex-col items-center gap-3 border-t border-[var(--color-line)] py-5 text-xs text-[var(--color-ink-2)] sm:flex-row sm:justify-between">
    <p>© {year} {site.name}. All rights reserved.</p>
    <div class="flex items-center gap-4">
      {socials.map((s) => (
        <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">
          <Icon name={s.icon as "github" | "x"} />
        </a>
      ))}
    </div>
  </div>
</footer>
