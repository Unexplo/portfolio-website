---
import Base from "@/layouts/Base.astro";
import Section from "@/components/Section.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import { newsletter, site } from "@/data/site";

const jsonLd = [
  {
    "@type": "Periodical",
    name: newsletter.name,
    description: `${newsletter.tagline} ${newsletter.description}`,
    url: `${site.url}/newsletter`,
    publisher: { "@id": `${site.url}/#organization` },
  },
];
---

<Base
  title="Newsletter"
  description={`${newsletter.name} — ${newsletter.tagline} ${newsletter.description}`}
  path="/newsletter"
  jsonLd={jsonLd}
>
  <Section eyebrow="Newsletter">
    <div class="grid gap-8 md:grid-cols-2 md:items-start">
      <div>
        <h1 class="text-3xl md:text-4xl">{newsletter.tagline}</h1>
        <p class="mt-4 text-lg text-[var(--color-ink-2)]">{newsletter.description}</p>
      </div>

      <div class="card p-5">
        <h2 class="font-display text-xl">Subscribe</h2>
        <p class="mt-1 text-sm text-[var(--color-ink-2)]">No spam. Unsubscribe anytime.</p>
        <div class="mt-4"><NewsletterForm /></div>
      </div>
    </div>

    <div class="mt-14">
      <p class="eyebrow">What you'll get</p>
      <h2 class="mt-3 text-2xl md:text-3xl">Every issue, three things</h2>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <div class="card p-7">
          <h3 class="font-display text-xl">AI you can actually use</h3>
          <p class="mt-2 leading-relaxed text-[var(--color-ink-2)]">
            Plain-language, no-hype notes on what AI can really do — and simple ways to put it to
            work in your everyday life.
          </p>
        </div>
        <div class="card p-7">
          <h3 class="font-display text-xl">First look at what we build</h3>
          <p class="mt-2 leading-relaxed text-[var(--color-ink-2)]">
            A front-row seat to every product we ship — early access, behind-the-scenes, and the
            thinking behind it.
          </p>
        </div>
        <div class="card p-7">
          <h3 class="font-display text-xl">Worth your time</h3>
          <p class="mt-2 leading-relaxed text-[var(--color-ink-2)]">
            Short, skimmable, and only when there's something worth sending. Real signal — no spam,
            no filler, no jargon.
          </p>
        </div>
      </div>
    </div>
  </Section>
</Base>
