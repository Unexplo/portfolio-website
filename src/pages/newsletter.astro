---
import Base from "@/layouts/Base.astro";
import Section from "@/components/Section.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import { newsletter, site } from "@/data/site";

const jsonLd = [
  {
    "@type": "Periodical",
    name: newsletter.name,
    description: `${newsletter.tagline} ${newsletter.description}`,
    url: `${site.url}/newsletter`,
    publisher: { "@id": `${site.url}/#organization` },
  },
];
---

<Base
  title="Newsletter"
  description={`${newsletter.name} — ${newsletter.tagline} ${newsletter.description}`}
  path="/newsletter"
  jsonLd={jsonLd}
>
  <Section eyebrow={newsletter.name} title={newsletter.tagline}>
    <p slot="lead" class="mt-4 max-w-2xl text-lg text-[var(--color-ink-2)]">
      {newsletter.description}
    </p>

    <div class="card max-w-2xl p-8">
      <h2 class="font-display text-xl">Subscribe</h2>
      <p class="mt-1.5 text-sm text-[var(--color-ink-2)]">One email a week. Unsubscribe anytime.</p>
      <div class="mt-5"><NewsletterForm /></div>
    </div>

    <div class="mt-4 grid max-w-2xl gap-4 sm:grid-cols-2">
      <div class="card p-7">
        <h3 class="font-display text-xl">AI you can actually use</h3>
        <p class="mt-2 leading-relaxed text-[var(--color-ink-2)]">
          Plain-language, no-hype notes on what AI can really do — and simple ways to put it to work
          in your everyday life.
        </p>
      </div>
      <div class="card p-7">
        <h3 class="font-display text-xl">First look at what we build</h3>
        <p class="mt-2 leading-relaxed text-[var(--color-ink-2)]">
          A front-row seat to every product we ship — early access, behind-the-scenes, and the
          thinking behind it.
        </p>
      </div>
    </div>
  </Section>
</Base>
