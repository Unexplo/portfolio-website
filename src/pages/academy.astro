---
import Base from "@/layouts/Base.astro";
import Section from "@/components/Section.astro";
import Icon from "@/components/Icon.astro";
import { academy, site } from "@/data/site";

const hasForm = Boolean(academy.formUrl);

const curriculum = [
  { t: "What AI actually is", d: "Models, tokens, context, and where today's systems shine or fail — in plain language." },
  { t: "Prompting that works", d: "Reliable patterns for getting useful output, with hands-on exercises." },
  { t: "Building with tools", d: "Connecting AI to real data and actions: tool use, retrieval, and agents." },
  { t: "Your first project", d: "Each participant ships a small working AI project by the end of the cohort." },
];

const jsonLd = [
  {
    "@type": "Course",
    name: `${academy.course} — Unexplo Academy`,
    description: `${academy.tagline} A live ${academy.capacity}-person cohort, no prior experience required.`,
    provider: { "@type": "Organization", name: "Unexplo", url: site.url, sameAs: "https://github.com/Unexplo" },
    url: "https://unexplo.com/academy",
    hasCourseInstance: {
      "@type": "CourseInstance",
      courseMode: "online",
      courseWorkload: "PT2H",
      maximumAttendeeCapacity: academy.capacity,
    },
  },
];
---

<Base
  title="Academy"
  description={`Unexplo Academy presents ${academy.course}: a live ${academy.capacity}-seat cohort class teaching how to build with modern AI from the ground up. No prior experience required.`}
  path="/academy"
  jsonLd={jsonLd}
>
  <Section eyebrow="Unexplo Academy" title={academy.course}>
    <p slot="lead" class="mt-4 max-w-2xl text-lg text-[var(--color-ink-2)]">
      {academy.tagline} A live {academy.capacity}-person cohort — no prior experience required.
    </p>

    <div class="flex flex-wrap gap-3 text-sm">
      <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] px-3.5 py-1.5">
        <Icon name="check" /> {academy.format}
      </span>
      <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] px-3.5 py-1.5">
        <Icon name="check" /> {academy.capacity} seats
      </span>
      <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] px-3.5 py-1.5">
        <Icon name="check" /> Beginner friendly
      </span>
    </div>
  </Section>

  <Section eyebrow="What you'll learn" title="Curriculum" class="!pt-0">
    <ol class="grid gap-5 sm:grid-cols-2">
      {curriculum.map((c, i) => (
        <li class="card p-6">
          <span class="font-mono text-sm text-[var(--color-coral)]">0{i + 1}</span>
          <h3 class="mt-2 font-display text-xl">{c.t}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-[var(--color-ink-2)]">{c.d}</p>
        </li>
      ))}
    </ol>
  </Section>

  <!-- Registration -->
  <Section eyebrow="Registration" title={`Reserve one of ${academy.capacity} seats`} id="register" class="border-t border-[var(--color-line)]">
    <p slot="lead" class="mt-4 max-w-xl text-[var(--color-ink-2)]">
      Seats are limited to keep the cohort hands-on. Register below and we'll confirm your place and share the schedule.
    </p>

    {hasForm ? (
      <div class="card overflow-hidden">
        <iframe
          src={academy.formUrl}
          title={`${academy.course} registration`}
          loading="lazy"
          class="h-[720px] w-full border-0"
        ></iframe>
      </div>
    ) : (
      <div class="card flex flex-col items-start gap-4 p-8">
        <p class="text-[var(--color-ink-2)]">
          Registration opens here once the cohort form is connected. To hold a seat now, email us.
        </p>
        <a href={`mailto:${site.email}?subject=Intro%20to%20AI%20cohort%20%E2%80%94%20seat%20request`} class="btn btn-primary">
          <Icon name="mail" /> Request a seat
        </a>
        <p class="text-xs text-[var(--color-ink-2)]">
          Set <code class="font-mono">PUBLIC_ACADEMY_FORM_URL</code> to embed your Tally / Google Form / Luma registration here.
        </p>
      </div>
    )}
  </Section>
</Base>
