---
import Base from "@/layouts/Base.astro";
import Section from "@/components/Section.astro";
import KanbanBoard from "@/components/KanbanBoard.astro";
import Icon from "@/components/Icon.astro";

const jsonLd = [
  {
    "@type": "WebPage",
    name: "Unexplo Roadmap",
    description: "A live Kanban view of what Unexplo is building across Labs, Academy, and open source.",
    url: "https://unexplo.com/roadmap",
  },
];
---

<Base
  title="Roadmap"
  description="A live Kanban board of what Unexplo is building — Labs experiments, the Intro to AI cohort, the Unexplored newsletter, and open-source work — synced from GitHub Projects."
  path="/roadmap"
  jsonLd={jsonLd}
>
  <Section eyebrow="Roadmap" title="What we're building">
    <p slot="lead" class="mt-4 max-w-2xl text-lg text-[var(--color-ink-2)]">
      A Kanban view across the Labs, the Academy, and our open-source work. This board syncs from our
      GitHub Projects, so it reflects the real state of play.
    </p>
    <KanbanBoard />
  </Section>

  <Section class="!pt-0">
    <div class="card flex flex-col items-start justify-between gap-4 p-8 sm:flex-row sm:items-center">
      <p class="text-sm text-[var(--color-ink-2)]">
        Want to contribute or follow along? Everything lives on GitHub.
      </p>
      <a href="https://github.com/Unexplo" target="_blank" rel="noopener" class="btn btn-ghost">
        <Icon name="github" /> github.com/Unexplo
      </a>
    </div>
  </Section>
</Base>
