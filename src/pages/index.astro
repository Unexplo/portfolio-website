---
import Base from "@/layouts/Base.astro";
import Section from "@/components/Section.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import Icon from "@/components/Icon.astro";
import { projects } from "@/data/projects";
import { site, academy, newsletter } from "@/data/site";

const featured = projects.slice(0, 4);

const jsonLd = [
  {
    "@type": "ItemList",
    name: "Unexplo Labs projects",
    itemListElement: projects.map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: p.name,
      description: p.description,
    })),
  },
];
---

<Base path="/" jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="dotfield relative overflow-hidden border-b border-[var(--color-line)]">
    <div class="wrap py-24 md:py-32">
      <p class="eyebrow flex items-center gap-2"><Icon name="spark" /> AI lab & implementation studio</p>
      <h1 class="mt-5 max-w-4xl text-5xl leading-[1.02] md:text-7xl">
        {site.tagline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-2)]">
        We run experiments, ship practical AI tools, and teach what we learn. Explore the Labs,
        join an Intro to AI cohort, and follow the work in the open.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/labs" class="btn btn-primary">Explore the Labs <Icon name="arrow" /></a>
        <a href="/academy" class="btn btn-ghost">Join the Academy</a>
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <Section class="!py-14">
    <div class="grid gap-4 md:grid-cols-3">
      {[
        { t: "Labs", d: "Four ongoing experiments in reading, memory, music, and gaming.", href: "/labs" },
        { t: "Academy", d: `${academy.course} — a live ${academy.capacity}-seat cohort for building with AI.`, href: "/academy" },
        { t: "Open source", d: "Tools we build in public on GitHub, including MCP servers and plugins.", href: "https://github.com/Unexplo" },
      ].map((p) => (
        <a href={p.href} class="card group p-6 transition-transform hover:-translate-y-1">
          <div class="flex items-center justify-between">
            <h3 class="font-display text-xl">{p.t}</h3>
            <Icon name="arrow" class="text-[var(--color-ink-2)] transition-transform group-hover:translate-x-0.5" />
          </div>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-2)]">{p.d}</p>
        </a>
      ))}
    </div>
  </Section>

  <!-- Labs preview -->
  <Section eyebrow="Unexplo Labs" title="Experiments and discovery">
    <p slot="lead" class="mt-4 text-[var(--color-ink-2)]">
      Four products we are actively exploring. Each starts as a question about what AI makes newly possible.
    </p>
    <div class="grid gap-5 sm:grid-cols-2">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="mt-8">
      <a href="/labs" class="inline-flex items-center gap-2 text-sm font-medium hover:text-[var(--color-coral)]">
        See all Labs work <Icon name="arrow" />
      </a>
    </div>
  </Section>

  <!-- Academy CTA -->
  <Section>
    <div class="card relative overflow-hidden p-8 md:p-12">
      <span class="dotfield absolute inset-0 opacity-60"></span>
      <div class="relative max-w-2xl">
        <p class="eyebrow">Unexplo Academy</p>
        <h2 class="mt-3 text-3xl md:text-4xl">{academy.course}</h2>
        <p class="mt-4 text-[var(--color-ink-2)]">
          {academy.tagline} A live {academy.capacity}-person cohort — no prior experience required.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/academy" class="btn btn-primary">Reserve a seat <Icon name="arrow" /></a>
          <span class="inline-flex items-center gap-2 self-center text-sm text-[var(--color-ink-2)]">
            <Icon name="check" /> {academy.format} · {academy.capacity} seats
          </span>
        </div>
      </div>
    </div>
  </Section>

  <!-- Newsletter -->
  <Section eyebrow="Unexplored" title={newsletter.tagline} id="newsletter">
    <p slot="lead" class="mt-4 max-w-xl text-[var(--color-ink-2)]">{newsletter.description}</p>
    <NewsletterForm />
  </Section>
</Base>
