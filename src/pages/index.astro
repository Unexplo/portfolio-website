---
import Base from "@/layouts/Base.astro";
import Section from "@/components/Section.astro";
import KanbanBoard from "@/components/KanbanBoard.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import Icon from "@/components/Icon.astro";
import { site, newsletter } from "@/data/site";
---

<Base path="/">
  <!-- Hero: the mission -->
  <section class="dotfield relative overflow-hidden border-b border-[var(--color-line)]">
    <div class="wrap py-24 md:py-32">
      <p class="eyebrow flex items-center gap-2"><Icon name="spark" /> Unexplo</p>
      <h1 class="mt-5 max-w-4xl text-5xl leading-[1.02] md:text-7xl">
        {site.tagline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-2)]">
        Unexplo collaborates and works with AI to help anyone understand it and put it to use.
        Don't be scared of AI — learn it, use it, and grow with us. That's what Unexplo is.
      </p>
    </div>
  </section>

  <!-- Roadmap: what we're building (the newsletter lives here as one product) -->
  <Section eyebrow="Roadmap" title="What we're building" id="roadmap">
    <p slot="lead" class="mt-4 max-w-2xl text-[var(--color-ink-2)]">
      The things we're exploring and shipping as we work with AI. More to come.
    </p>
    <KanbanBoard />
  </Section>

  <!-- Newsletter: one of the products, modestly placed -->
  <Section eyebrow={newsletter.name} title={newsletter.tagline} id="newsletter">
    <p slot="lead" class="mt-4 max-w-xl text-[var(--color-ink-2)]">{newsletter.description}</p>
    <NewsletterForm />
    <p class="mt-3 text-xs text-[var(--color-muted)]">One email a week. Unsubscribe anytime.</p>
  </Section>
</Base>
