---
import Base from "@/layouts/Base.astro";
import Section from "@/components/Section.astro";
import Icon from "@/components/Icon.astro";
import { site, newsletter } from "@/data/site";

const pillars = [
  {
    t: "AI for everyone",
    d: "Not built for experts or the few. We make AI approachable so anyone can pick it up and put it to work in their own life.",
  },
  {
    t: "With people, not against them",
    d: "We build AI to amplify what people do — not to replace them. Tools that work alongside you, so there's nothing to fear.",
  },
  {
    t: "Woven into everyday life",
    d: "The best AI fades into the background — quietly making ordinary moments at work, at home, and in between a little easier.",
  },
  {
    t: "Real help over hype",
    d: "We care about what genuinely helps real people, not demos that dazzle for a minute and disappear.",
  },
];

const paths = [
  {
    t: "Get better with AI weekly",
    d: `${newsletter.name} — ${newsletter.tagline} Plain-language, for everyone.`,
    href: "/newsletter",
  },
];

const jsonLd = [
  {
    "@type": "SiteNavigationElement",
    name: ["Home", "Newsletter"],
    url: [`${site.url}/`, `${site.url}/newsletter`],
  },
];
---

<Base path="/" jsonLd={jsonLd}>
  <!-- Hero: the mission -->
  <section class="relative overflow-hidden border-b border-[var(--color-line)]">
    <span class="dotfield dotfield-mask absolute inset-0" aria-hidden="true"></span>
    <span class="glow -top-40 left-1/4 h-[32rem] w-[32rem]" aria-hidden="true"></span>
    <div class="wrap relative z-10 py-28 md:py-40">
      <p class="eyebrow flex items-center gap-2"><Icon name="spark" /> Unexplo</p>
      <h1 class="mt-6 max-w-4xl text-5xl leading-[1.02] md:text-7xl">
        The <span class="text-grad">AI</span> age is here.<br />We're making it <span class="italic">ours</span>.
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-2)]">
        Not a tool for the few — a force on everyone's side. We're building a future where AI works
        with people, woven into the fabric of everyday life.
      </p>
    </div>
  </section>

  <!-- What we do -->
  <Section eyebrow="What we do" title="What we're about">
    <div class="grid gap-4 sm:grid-cols-2">
      {pillars.map((p, i) => (
        <div class="card group relative overflow-hidden p-7 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-coral)]/30 md:p-9">
          <span class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--color-coral)] to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" aria-hidden="true"></span>
          <span class="glow -right-16 -top-16 h-40 w-40 !opacity-0 transition-opacity duration-300 group-hover:!opacity-25" aria-hidden="true"></span>
          <span class="relative font-mono text-sm text-[var(--color-muted)]">0{i + 1}</span>
          <h3 class="relative mt-4 font-display text-2xl md:text-3xl">{p.t}</h3>
          <p class="relative mt-3 leading-relaxed text-[var(--color-ink-2)]">{p.d}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Where to go next -->
  <Section eyebrow="Start here" title="Get started">
    <div class="grid gap-4">
      {paths.map((p) => (
        <a href={p.href} class="card group p-6 transition-transform hover:-translate-y-1">
          <div class="flex items-center justify-between">
            <h3 class="font-display text-xl">{p.t}</h3>
            <Icon name="arrow" class="text-[var(--color-ink-2)] transition-transform group-hover:translate-x-0.5" />
          </div>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-2)]">{p.d}</p>
        </a>
      ))}
    </div>
  </Section>
</Base>
