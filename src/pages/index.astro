---
import Base from "@/layouts/Base.astro";
import Section from "@/components/Section.astro";
import Icon from "@/components/Icon.astro";
import { site, newsletter } from "@/data/site";

const pillars = [
  {
    t: "Collaborate with AI",
    d: "We partner with modern AI to design, build, and ship real things — products, tools, and experiments worth making.",
  },
  {
    t: "AI for everyday life",
    d: "We help people cut past the hype and actually use AI — at work, in creative projects, and in day-to-day life.",
  },
];

const paths = [
  {
    t: "See what we're building",
    d: "Our roadmap of what we're exploring and shipping as we work with AI.",
    href: "/roadmap",
  },
  {
    t: "Get better with AI weekly",
    d: `${newsletter.name} — ${newsletter.tagline} Plain-language, for everyone.`,
    href: "/newsletter",
  },
];

const jsonLd = [
  {
    "@type": "SiteNavigationElement",
    name: ["Home", "Roadmap", "Newsletter"],
    url: [`${site.url}/`, `${site.url}/roadmap`, `${site.url}/newsletter`],
  },
];
---

<Base path="/" jsonLd={jsonLd}>
  <!-- Hero: the mission -->
  <section class="dotfield relative overflow-hidden border-b border-[var(--color-line)]">
    <div class="wrap py-24 md:py-32">
      <p class="eyebrow flex items-center gap-2"><Icon name="spark" /> Unexplo</p>
      <h1 class="mt-5 max-w-4xl text-5xl leading-[1.02] md:text-7xl">
        {site.tagline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-2)]">
        Unexplo is two things: we collaborate with AI to build things worth making, and we help
        people understand how to use AI to make everyday life better.
      </p>
    </div>
  </section>

  <!-- What we do -->
  <Section eyebrow="What we do" title="Two things, one frontier">
    <div class="grid gap-4 sm:grid-cols-2">
      {pillars.map((p) => (
        <div class="card p-6 md:p-8">
          <h3 class="font-display text-xl md:text-2xl">{p.t}</h3>
          <p class="mt-3 leading-relaxed text-[var(--color-ink-2)]">{p.d}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Where to go next -->
  <Section eyebrow="Start here" title="Two ways in">
    <div class="grid gap-4 md:grid-cols-2">
      {paths.map((p) => (
        <a href={p.href} class="card group p-6 transition-transform hover:-translate-y-1">
          <div class="flex items-center justify-between">
            <h3 class="font-display text-xl">{p.t}</h3>
            <Icon name="arrow" class="text-[var(--color-ink-2)] transition-transform group-hover:translate-x-0.5" />
          </div>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-2)]">{p.d}</p>
        </a>
      ))}
    </div>
  </Section>
</Base>
