---
import Base from "@/layouts/Base.astro";
import Icon from "@/components/Icon.astro";
---

<Base title="Not found" path="/404" noindex>
  <section class="wrap grid min-h-[60vh] place-items-center py-24 text-center">
    <div>
      <p class="eyebrow">404</p>
      <h1 class="mt-4 text-5xl">This page is still unexplored.</h1>
      <p class="mt-4 text-[var(--color-ink-2)]">The page you're looking for doesn't exist — yet.</p>
      <a href="/" class="btn btn-primary mt-8">Back home <Icon name="arrow" /></a>
    </div>
  </section>
</Base>
